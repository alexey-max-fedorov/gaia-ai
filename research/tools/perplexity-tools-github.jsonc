        "base": { "type": "string" },
        "direction": { "enum": ["asc", "desc"], "type": "string" },
        "head": { "type": "string" },
        "owner": { "type": "string" },
        "page": { "minimum": 1, "type": "number" },
        "perPage": { "maximum": 100, "minimum": 1, "type": "number" },
        "repo": { "type": "string" },
        "sort": { "enum": ["created", "updated", "popularity", "long-running"], "type": "string" },
        "state": { "enum": ["open", "closed", "all"], "type": "string" }
      },
      "required": ["owner", "repo", "_tool_input_summary", "_requires_user_approval"],
      "type": "object"
    }
  },

