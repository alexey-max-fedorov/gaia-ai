        "owner": { "type": "string" }
      },
      "required": ["owner", "_tool_input_summary", "_requires_user_approval"],
      "type": "object"
    }
  },

  { // GITHUB LIST ISSUES TOOL
    "description": "List issues in a GitHub repository.",
    "name": "mcp_tool_github_mcp_direct_list_issues",
    "parameters": {
      "additionalProperties": false,
      "properties": {
        "_requires_user_approval": { "type": "boolean" },
        "_tool_input_summary": { "type": "string" },
        "after": { "type": "string" },
        "direction": { "enum": ["ASC", "DESC"], "type": "string" },
        "labels": { "items": { "type": "string" }, "type": "array" },
        "orderBy": { "enum": ["CREATED_AT", "UPDATED_AT", "COMMENTS"], "type": "string" },
        "owner": { "type": "string" },
        "perPage": { "maximum": 100, "minimum": 1, "type": "number" },
        "repo": { "type": "string" },
        "since": { "type": "string" },
        "state": { "enum": ["OPEN", "CLOSED"], "type": "string" }
      },
      "required": ["owner", "repo", "_tool_input_summary", "_requires_user_approval"],
      "type": "object"
    }
  },

  { // GITHUB LIST PULL REQUESTS TOOL
    "description": "List pull requests in a GitHub repository.",
    "name": "mcp_tool_github_mcp_direct_list_pull_requests",
    "parameters": {
      "additionalProperties": false,
      "properties": {
        "_requires_user_approval": { "type": "boolean" },
