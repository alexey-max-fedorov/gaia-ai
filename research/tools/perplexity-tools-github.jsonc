        "_tool_input_summary": { "type": "string" },
        "commit_message": { "type": "string" },
        "commit_title": { "type": "string" },
        "merge_method": { "enum": ["merge", "squash", "rebase"], "type": "string" },
        "owner": { "type": "string" },
        "pullNumber": { "type": "number" },
        "repo": { "type": "string" }
      },
      "required": ["owner", "repo", "pullNumber", "_tool_input_summary", "_requires_user_approval"],
      "type": "object"
    }
  },

  { // GITHUB READ PULL REQUEST TOOL
    "description": "Get information on a specific pull request in GitHub repository.",
