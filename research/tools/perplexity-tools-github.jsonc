      },
      "required": ["method", "owner", "repo", "pullNumber", "_tool_input_summary", "_requires_user_approval"],
      "type": "object"
    }
  },

  { // GITHUB PULL REQUEST REVIEW TOOL
    "description": "Create and/or submit, delete review of a pull request.",
    "name": "mcp_tool_github_mcp_direct_pull_request_review_write",
    "parameters": {
      "additionalProperties": false,
      "properties": {
        "_requires_user_approval": { "type": "boolean" },
